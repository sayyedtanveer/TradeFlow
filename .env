# ─────────────────────────────────────────────
# MedTrack ERP – Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
ENVIRONMENT=development
APP_NAME="MedTrack ERP"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:123@localhost:5432/medtrack
# Sync URL used only by Alembic migrations
DATABASE_SYNC_URL=postgresql://postgres:123@localhost:5432/medtrack

# ── JWT ──────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── File Storage ─────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── Redis (optional – for future event bus / cache) ───
REDIS_URL=redis://localhost:6379/0

# ── Email (stub – values unused in Phase 0) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=changeme
